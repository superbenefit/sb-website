{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sb-website",
  "main": "./dist/_worker.js/index.js",
  "compatibility_date": "2025-12-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "placement": {
    "mode": "smart"
  },
  "limits": {
    "cpu_ms": 10000
  }
}
