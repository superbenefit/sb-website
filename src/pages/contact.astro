---
import { actions, isInputError } from 'astro:actions';
import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionDivider from '../components/SectionDivider.astro';
import CallToAction from '../components/CallToAction.astro';

const siteKey = env.PUBLIC_TURNSTILE_SITE_KEY;
if (!siteKey) {
  throw new Error(
    'Server misconfiguration: PUBLIC_TURNSTILE_SITE_KEY is not set. ' +
      'Add it to wrangler.jsonc [vars] (it must be a [var], not a ' +
      'secret, because the value is exposed to the client bundle).',
  );
}

const result = Astro.getActionResult(actions.contact);
const inputErrors = isInputError(result?.error) ? result.error.fields : {};
const generalError =
  result?.error && !isInputError(result?.error)
    ? result.error.message
    : null;
const success = result?.data?.ok === true;

const hero = {
  title: 'Get in touch',
  subtitle: "We read every message. Tell us what you're working on.",
  overlayGradient: `linear-gradient(
    to bottom,
    color-mix(in srgb, var(--color-green-sage) 30%, transparent) 0%,
    color-mix(in srgb, var(--color-charcoal) 70%, transparent) 50%,
    color-mix(in srgb, var(--color-black) 95%, transparent) 100%
  )`,
  showStars: true,
};
---

<BaseLayout
  title="Contact — SuperBenefit"
  description="Get in touch with SuperBenefit. We work with aligned organizations, networks, and contributors on governance, research, and regenerative systems."
>
  <PageHero {...hero} />

  <SectionDivider from="black" to="cream" />

  <section class="contact-form-section">
    <div class="container">
      {success && (
        <div class="contact-banner contact-banner-success" role="status">
          <strong>Thanks — your message is on its way.</strong>
          We'll be in touch within a few days.
        </div>
      )}

      {generalError && (
        <div class="contact-banner contact-banner-error" role="alert">
          {generalError}
        </div>
      )}

      <div class="contact-grid">
        <aside class="contact-aside">
          <span class="section-label">Contact</span>
          <h2>How we work</h2>
          <p>
            SuperBenefit is a small network. We respond personally and try
            to be useful even when a formal engagement isn't the right fit.
            For project proposals, partnership ideas, speaking, or just to
            say hello — the form is the fastest path.
          </p>
          <p class="contact-aside-meta">
            Prefer email? Reach us at
            <a href="mailto:contact@superbenefit.org">contact@superbenefit.org</a>.
          </p>
        </aside>

        <form class="contact-form" method="POST" action={actions.contact}>
          <div class="contact-field">
            <label for="name">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              maxlength="120"
              autocomplete="name"
            />
            {inputErrors.name && (
              <p class="contact-field-error">{inputErrors.name.join(', ')}</p>
            )}
          </div>

          <div class="contact-field">
            <label for="email">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              maxlength="200"
              autocomplete="email"
            />
            {inputErrors.email && (
              <p class="contact-field-error">{inputErrors.email.join(', ')}</p>
            )}
          </div>

          <div class="contact-field">
            <label for="subject">Subject</label>
            <input
              type="text"
              id="subject"
              name="subject"
              required
              maxlength="200"
            />
            {inputErrors.subject && (
              <p class="contact-field-error">{inputErrors.subject.join(', ')}</p>
            )}
          </div>

          <div class="contact-field">
            <label for="message">Message</label>
            <textarea
              id="message"
              name="message"
              required
              rows="6"
              maxlength="5000"
            ></textarea>
            {inputErrors.message && (
              <p class="contact-field-error">{inputErrors.message.join(', ')}</p>
            )}
          </div>

          <div class="contact-turnstile">
            <div
              class="cf-turnstile"
              data-sitekey={siteKey}
              data-theme="light"
            ></div>
            {inputErrors['cf-turnstile-response'] && (
              <p class="contact-field-error">
                {inputErrors['cf-turnstile-response'].join(', ')}
              </p>
            )}
          </div>

          <button type="submit" class="contact-submit">
            Send message
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14"></path>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </button>
        </form>
      </div>
    </div>
  </section>

  <SectionDivider from="cream" to="charcoal" />

  <CallToAction />
</BaseLayout>

<!-- Turnstile widget loader. is:inline so Astro does not try to bundle it.
     Cloudflare's CDN is the canonical source. The widget auto-injects a
     hidden input named `cf-turnstile-response` into the form on success. -->
<script
  src="https://challenges.cloudflare.com/turnstile/v0/api.js"
  async
  defer
  is:inline
></script>

<style>
  .contact-form-section {
    background: var(--color-cream);
    padding-block: var(--space-2xl);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: start;
  }
  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
    }
  }

  .contact-aside .section-label {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-orange);
    margin-block-end: var(--space-sm);
  }
  .contact-aside h2 {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    color: var(--color-charcoal);
    margin-block-end: var(--space-md);
  }
  .contact-aside p {
    color: var(--color-charcoal);
    opacity: 0.8;
    line-height: 1.7;
    max-width: 60ch;
    margin-block-end: var(--space-md);
  }
  .contact-aside-meta a {
    color: var(--color-orange);
  }

  .contact-form {
    display: grid;
    gap: var(--space-md);
  }

  .contact-field {
    display: grid;
    gap: var(--space-xs);
  }
  .contact-field label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-charcoal);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .contact-field input,
  .contact-field textarea {
    font: inherit;
    color: var(--color-charcoal);
    background: var(--color-cream-light);
    border: 1px solid rgb(var(--color-black-rgb) / 0.12);
    border-radius: 6px;
    padding: var(--space-sm) var(--space-md);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    width: 100%;
    box-sizing: border-box;
    transition: border-color var(--transition-fast);
  }
  .contact-field input:focus,
  .contact-field textarea:focus {
    outline: none;
    border-color: var(--color-orange);
    box-shadow: 0 0 0 3px rgb(var(--color-orange-rgb) / 0.15);
  }
  .contact-field textarea {
    resize: vertical;
    min-height: 8rem;
    line-height: 1.6;
  }
  .contact-field-error {
    font-size: var(--text-xs);
    color: var(--color-red);
    margin: 0;
  }

  .contact-turnstile {
    margin-block: var(--space-sm);
  }
  .contact-turnstile .contact-field-error {
    margin-block-start: var(--space-xs);
  }

  .contact-submit {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-cream);
    background: var(--color-orange);
    border: none;
    border-radius: 6px;
    padding: var(--space-md) var(--space-lg);
    cursor: pointer;
    transition: background var(--transition-fast);
    justify-self: start;
  }
  .contact-submit:hover {
    background: var(--color-orange-dark);
  }

  .contact-banner {
    padding: var(--space-md) var(--space-lg);
    border-radius: 6px;
    margin-block-end: var(--space-xl);
    font-size: var(--text-base);
  }
  .contact-banner-success {
    background: rgb(var(--color-green-rgb) / 0.12);
    border: 1px solid rgb(var(--color-green-rgb) / 0.4);
    color: var(--color-charcoal);
  }
  .contact-banner-error {
    background: rgb(var(--color-red-rgb) / 0.1);
    border: 1px solid rgb(var(--color-red-rgb) / 0.4);
    color: var(--color-red-deep);
  }
</style>
