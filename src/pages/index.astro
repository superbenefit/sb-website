      posts={recentPosts}
    >
      <p class="story-cta-blurb">Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi.</p>
      <a href="/events" class="story-btn story-btn--primary">
        <svg class="btn-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        View Events
      </a>
