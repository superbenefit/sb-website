---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionDivider from '../components/SectionDivider.astro';

const hero = {
  title: 'About SuperBenefit',
  subtitle: 'A node in the regenerative ecosystem',
  overlayGradient: `linear-gradient(
    to bottom,
    color-mix(in srgb, var(--color-orange) 70%, transparent) 0%,
    color-mix(in srgb, var(--color-red) 80%, transparent) 50%,
    color-mix(in srgb, var(--color-charcoal) 95%, transparent) 100%
  )`,
  minHeight: '50vh',
};
---

<BaseLayout
  title="About — SuperBenefit"
  description="A node in the regenerative ecosystem, harnessing web3 and AI to shift power and to grow new systems of coordination: open source, peer-to-peer, built to be forked."
>
  <PageHero {...hero} />

  <SectionDivider from="charcoal" to="cream" />

  <!-- Mission Section -->
  <section class="about-mission">
    <div class="container mission-content" data-animate="fade-up">
      <span class="section-label">Our Mission</span>
      <h2>Emerging technologies are a rare opportunity. Not a silver bullet, but the potential to intervene at the deepest levels of how power flows.</h2>
      <div class="mission-columns">
        <div>
          <p>
            Our current systems of coordination - how we organize, allocate resources, govern ourselves, make collective decisions - clearly aren't working for most people. Value is extracted rather than circulated, power ever more concentrated, our planet and people devastated.
          </p>
          <p>
            Meanwhile, across the world, there is a hidden mosaic of grassroots initiatives yearning to be woven. Open source, peer-to-peer, built to be forked.
          </p>
        </div>
        <div>
          <p>
            SuperBenefit is one part of a much larger regenerative ecosystem. Together, we are building the commons and cultivating the connective tissue between disparate communities, initiatives, technologies, and bioregions.
          </p>
          <p>
            Through projects like the <a href="https://knowledge.superbenefit.dev/docs/" target="_blank" rel="noopener noreferrer">Reimagining Power Project</a> and <a href="https://www.allinforsport.org/" target="_blank" rel="noopener noreferrer">All In For Sport</a>, we work alongside partners across multiple continents, experimenting with decentralized tools to shift ownership and agency to communities that have been excluded from the systems that shape their lives.
          </p>
        </div>
      </div>
      <blockquote class="pull-quote">
        "Not just reimagining existing systems, but growing new ones alongside them."
      </blockquote>
    </div>
  </section>

  <SectionDivider from="cream" to="green" />

  {/* Values */}
  <section class="about-values">
    <div class="container">
      <header class="values-header" data-animate="fade-up">
        <span class="section-label">Our Values</span>
        <h2>What guides our work</h2>
      </header>
      <div class="values-grid">
        <div class="value-card" data-animate="fade-up" style="--stagger: 0ms">
          <span class="value-icon" aria-hidden="true">&darr;</span>
          <h3>Open Source</h3>
          <p>Everything we build is open source, licensed for anyone to use, adapt, and fork. Transparency is the foundation of trust.</p>
        </div>
        <div class="value-card" data-animate="fade-up" style="--stagger: 80ms">
          <span class="value-icon" aria-hidden="true">&harr;</span>
          <h3>Peer-to-Peer</h3>
          <p>We organize as a network of peers — not a hierarchy. Power is distributed, decisions are made by those affected by them.</p>
        </div>
        <div class="value-card" data-animate="fade-up" style="--stagger: 160ms">
          <span class="value-icon" aria-hidden="true">&olarr;</span>
          <h3>Regenerative</h3>
          <p>Our work aims to regenerate social, ecological, and economic systems — creating cycles of value that circulate rather than extract.</p>
        </div>
        <div class="value-card" data-animate="fade-up" style="--stagger: 0ms">
          <span class="value-icon" aria-hidden="true">&sung;</span>
          <h3>Translocal</h3>
          <p>We are rooted in specific places and communities while connected globally. Local autonomy, translocal solidarity.</p>
        </div>
        <div class="value-card" data-animate="fade-up" style="--stagger: 80ms">
          <span class="value-icon" aria-hidden="true">&circlearrowleft;</span>
          <h3>Commons-Based</h3>
          <p>We build and steward shared resources — knowledge, code, infrastructure, and capital — governed by the communities that rely on them.</p>
        </div>
        <div class="value-card" data-animate="fade-up" style="--stagger: 160ms">
          <span class="value-icon" aria-hidden="true">&weierp;</span>
          <h3>Systems Thinking</h3>
          <p>We see the whole system, not isolated parts. Our interventions aim to shift underlying patterns, not just surface symptoms.</p>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider from="green" to="cream" />

  {/* Theory of Change */}
  <section class="about-toc">
    <div class="container">
      <span class="section-label" data-animate="fade-up">Theory of Change</span>
      <h2 data-animate="fade-up">How we work</h2>
      <div class="toc-steps">
        <div class="toc-step" data-animate="fade-up" style="--stagger: 0ms">
          <div class="step-number">01</div>
          <div class="step-connector" aria-hidden="true"></div>
          <h3>Convene</h3>
          <p>We bring together builders, researchers, and community leaders who are working at the edges of systems change. Through gatherings, salons, and shared spaces, we create the conditions for trust, learning, and collaboration across disciplines and geographies.</p>
        </div>
        <div class="toc-step" data-animate="fade-up" style="--stagger: 100ms">
          <div class="step-number">02</div>
          <div class="step-connector" aria-hidden="true"></div>
          <h3>Coordinate</h3>
          <p>We develop shared infrastructure, capital allocation mechanisms, and governance patterns that enable autonomous teams to work together without centralized control. Our DAO primitives framework provides modular building blocks for designing purpose-aligned networks.</p>
        </div>
        <div class="toc-step" data-animate="fade-up" style="--stagger: 200ms">
          <div class="step-number">03</div>
          <h3>Catalyze</h3>
          <p>We launch and support initiatives that create regenerative outcomes — from decentralized governance experiments to community-owned infrastructure. Each initiative produces knowledge, tools, and patterns that feed back into the ecosystem.</p>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider from="cream" to="charcoal" />

  {/* Community */}
  <section class="about-community">
    <div class="container community-content" data-animate="fade-up">
      <h2>Pull Up a Chair</h2>
      <p>
        If our work resonates, we warmly invite you to connect. SuperBenefit
        is an open community — whether you're a builder, researcher, funder,
        or simply curious, there's a place for you here.
      </p>
      <div class="community-links">
        <a
          href="https://discord.gg/q95fFXGu67"
          class="community-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="link-icon" aria-hidden="true">&#9679;</span>
          Discord
        </a>
        <a
          href="https://github.com/superbenefit"
          class="community-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="link-icon" aria-hidden="true">&#9900;</span>
          GitHub
        </a>
        <a
          href="https://knowledge.superbenefit.org"
          class="community-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="link-icon" aria-hidden="true">&#9733;</span>
          Knowledge Garden
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== Section Label ===== */
  .section-label {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-orange);
    margin-block-end: var(--space-sm);
  }

  /* ===== Mission ===== */
  .about-mission {
    background: var(--color-cream);
    padding-block: var(--space-2xl);
  }

  .mission-content {
    max-width: 900px;
  }

  .mission-content h2 {
    margin-block-end: var(--space-xl);
    max-width: 700px;
  }

  .mission-columns {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    margin-block-end: var(--space-xl);
  }

  @media (min-width: 768px) {
    .mission-columns {
      grid-template-columns: 1fr 1fr;
    }
  }

  .mission-columns p {
    color: var(--color-charcoal);
    opacity: 0.8;
    line-height: 1.7;
    margin-block-end: var(--space-md);
  }

  .mission-columns a {
    color: var(--color-orange);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: opacity var(--transition-fast);
  }

  .mission-columns a:hover {
    opacity: 0.7;
  }

  .pull-quote {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-style: italic;
    color: var(--color-orange);
    border-inline-start: 4px solid var(--color-gold);
    padding-inline-start: var(--space-lg);
    margin-block-start: var(--space-lg);
  }

  /* ===== Values ===== */
  .about-values {
    background: var(--color-green-sage);
    padding-block: var(--space-2xl);
  }

  .values-header {
    text-align: center;
    margin-block-end: var(--space-xl);
  }

  .values-header .section-label {
    color: var(--color-charcoal);
    opacity: 0.7;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-lg);
  }

  .value-card {
    background: var(--color-cream-light);
    border-radius: 12px;
    padding: var(--space-xl) var(--space-lg);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-medium), box-shadow var(--transition-medium);
    animation-delay: var(--stagger);
  }

  .value-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .value-icon {
    display: block;
    font-size: 2rem;
    color: var(--color-orange);
    margin-block-end: var(--space-sm);
  }

  .value-card h3 {
    margin-block-end: var(--space-xs);
  }

  .value-card p {
    font-size: var(--text-sm);
    color: var(--color-charcoal);
    opacity: 0.75;
    line-height: 1.7;
  }

  /* ===== Theory of Change ===== */
  .about-toc {
    background: var(--color-cream);
    padding-block: var(--space-2xl);
  }

  .about-toc h2 {
    margin-block-end: var(--space-xl);
  }

  .toc-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 768px) {
    .toc-steps {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-lg);
    }
  }

  .toc-step {
    position: relative;
    animation-delay: var(--stagger);
  }

  .step-number {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: 900;
    color: var(--color-orange);
    opacity: 0.3;
    line-height: 1;
    margin-block-end: var(--space-sm);
  }

  .step-connector {
    display: none;
  }

  @media (min-width: 768px) {
    .step-connector {
      display: block;
      position: absolute;
      top: 2rem;
      right: calc(-1 * var(--space-lg) / 2 - 20px);
      width: 40px;
      height: 2px;
      background: linear-gradient(to right, var(--color-orange), transparent);
    }

    .toc-step:last-child .step-connector {
      display: none;
    }
  }

  .toc-step h3 {
    color: var(--color-charcoal);
    margin-block-end: var(--space-xs);
  }

  .toc-step p {
    font-size: var(--text-sm);
    color: var(--color-charcoal);
    opacity: 0.75;
    line-height: 1.7;
  }

  /* ===== Community ===== */
  .about-community {
    background: var(--color-charcoal);
    padding-block: var(--space-2xl);
  }

  .community-content {
    text-align: center;
    max-width: 640px;
  }

  .community-content h2 {
    color: var(--color-cream);
    margin-block-end: var(--space-md);
  }

  .community-content > p {
    color: var(--color-cream);
    opacity: 0.8;
    font-size: var(--text-lg);
    line-height: 1.7;
    margin-block-end: var(--space-xl);
    margin-inline: auto;
  }

  .community-links {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .community-link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.7em 1.5em;
    border: 1px solid rgb(var(--color-cream-rgb) / 0.2);
    border-radius: 50px;
    color: var(--color-cream);
    font-weight: 500;
    font-size: var(--text-sm);
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast),
      transform var(--transition-fast),
      color var(--transition-fast);
    text-decoration: none;
  }

  .community-link:hover {
    background: var(--color-orange);
    border-color: var(--color-orange);
    color: var(--color-cream);
    transform: translateY(-2px);
  }

  .link-icon {
    font-size: 1.2em;
  }
</style>
