---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import SectionDivider from '../components/SectionDivider.astro';

const values = [
  {
    icon: '&#9878;',
    title: 'Systems Transformation',
    description: 'We\'re not interested in tweaking the edges. We\'re exploring how to shift the paradigms that shape how society organizes, allocates resources, and makes decisions.',
  },
  {
    icon: '&#10047;',
    title: 'Practical Experimentation',
    description: 'Theory matters, but so does practice. We build real projects, test governance designs, and learn from what works (and what doesn\'t).',
  },
  {
    icon: '&#9733;',
    title: 'Open Knowledge',
    description: 'What we learn, we share. Our knowledge garden is a living commons - patterns, frameworks, and insights available for anyone to use and build on.',
  },
  {
    icon: '&#10070;',
    title: 'Community First',
    description: 'The future gets built by communities, not corporations. We\'re investing in the relationships, trust, and coordination capacity that make collective action possible.',
  },
];

const steps = [
  { label: 'Invention', description: 'We explore new ideas and technologies - from DAOs to regenerative economics - asking what\'s possible that wasn\'t before.' },
  { label: 'Investment', description: 'We put resources (time, attention, sometimes capital) behind experiments that test our hypotheses about coordination and governance.' },
  { label: 'Acceleration', description: 'We share what we learn openly, so others can build on our work and the whole field moves forward faster.' },
];
---

<BaseLayout
  title="About - SuperBenefit"
  description="SuperBenefit is building the social and financial flywheels to accelerate a better world through web3, governance innovation, and systems transformation."
>
  <!-- About Hero -->
  <section class="about-hero">
    <div class="about-hero-overlay"></div>
    <div class="container about-hero-content">
      <h1>About SuperBenefit</h1>
      <p class="about-hero-sub">Make better faster</p>
    </div>
  </section>

  <SectionDivider from="charcoal" to="cream" />

  <!-- Mission Section -->
  <section class="about-mission">
    <div class="container mission-content" data-animate="fade-up">
      <span class="section-label">Our Purpose</span>
      <h2>Embed universal abundance into the core infrastructure of the future.</h2>
      <div class="mission-columns">
        <div>
          <p>
            SuperBenefit exists to develop the social and financial flywheels that enable invention, investment, and acceleration of a better world.
          </p>
          <p>
            We're a community of technologists, artists, activists, and social entrepreneurs exploring how web3 technologies can drive systems transformation - not just incremental change, but deep paradigm shifts toward equitable, regenerative outcomes.
          </p>
        </div>
        <div>
          <p>
            Our work draws on Donella Meadows' leverage points - we believe web3 gives us tools to intervene at the deepest levels of systems, not just tweak parameters.
          </p>
          <p>
            From tokenized funding mechanisms to fractal governance models, we're building practical tools for coordination that can scale while staying aligned with their purpose.
          </p>
        </div>
      </div>
      <blockquote class="pull-quote">
        "We need to make better faster. The time for incremental change has passed."
      </blockquote>
    </div>
  </section>

  <SectionDivider from="cream" to="green" />

  <!-- Values Section -->
  <section class="about-values">
    <div class="container">
      <div class="values-header" data-animate="fade-up">
        <span class="section-label">Our Values</span>
        <h2>What We Believe</h2>
      </div>
      <div class="values-grid">
        {values.map((v, i) => (
          <article
            class="value-card"
            data-animate="scale-in"
            style={`--stagger: ${i * 80}ms`}
          >
            <span class="value-icon" set:html={v.icon} />
            <h3>{v.title}</h3>
            <p>{v.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <SectionDivider from="green" to="cream" />

  <!-- Theory of Change -->
  <section class="about-toc">
    <div class="container" data-animate="fade-up">
      <span class="section-label">Theory of Change</span>
      <h2>How We Create Impact</h2>
      <div class="toc-steps">
        {steps.map((step, i) => (
          <div class="toc-step" data-animate="fade-up" style={`--stagger: ${i * 120}ms`}>
            <div class="step-number">{String(i + 1).padStart(2, '0')}</div>
            <div class="step-connector" aria-hidden="true"></div>
            <h3>{step.label}</h3>
            <p>{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <SectionDivider from="cream" to="charcoal" />

  <!-- Community Section -->
  <section class="about-community">
    <div class="container community-content" data-animate="fade-up">
      <h2>Join Our Community</h2>
      <p>
        We're a distributed community exploring new ways to coordinate, govern, and create impact together. 
        Whether you're a builder, researcher, or just curious about the future of organizations - there's a place for you here.
      </p>
      <div class="community-links">
        <a href="https://discord.gg/d2EeszTvVm" target="_blank" rel="noopener noreferrer" class="community-link">
          <span class="link-icon">&#128172;</span>
          <span>Discord</span>
        </a>
        <a href="https://paragraph.com/@superbenefit-2" target="_blank" rel="noopener noreferrer" class="community-link">
          <span class="link-icon">&#128220;</span>
          <span>Paragraph</span>
        </a>
        <a href="https://github.com/superbenefit" target="_blank" rel="noopener noreferrer" class="community-link">
          <span class="link-icon">&#128187;</span>
          <span>GitHub</span>
        </a>
        <a href="https://knowledge.superbenefit.org" target="_blank" rel="noopener noreferrer" class="community-link">
          <span class="link-icon">&#128218;</span>
          <span>Knowledge</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== About Hero ===== */
  .about-hero {
    position: relative;
    background: var(--color-charcoal);
    background-image: url('/images/brand-showcase.webp');
    background-size: cover;
    background-position: center;
    padding-block-start: calc(var(--header-height) + var(--space-2xl));
    padding-block-end: var(--space-2xl);
    min-height: 50vh;
    display: flex;
    align-items: flex-end;
  }

  .about-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(245, 135, 44, 0.7) 0%,
      rgba(196, 64, 26, 0.8) 50%,
      rgba(45, 45, 45, 0.95) 100%
    );
  }

  .about-hero-content {
    position: relative;
    z-index: 1;
  }

  .about-hero h1 {
    color: var(--color-cream);
    font-size: var(--text-3xl);
    margin-block-end: var(--space-xs);
  }

  .about-hero-sub {
    color: var(--color-cream);
    opacity: 0.8;
    font-size: var(--text-xl);
    font-family: var(--font-serif);
    font-style: italic;
  }

  /* ===== Section Label ===== */
  .section-label {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-orange);
    margin-block-end: var(--space-sm);
  }

  /* ===== Mission ===== */
  .about-mission {
    background: var(--color-cream);
    padding-block: var(--space-2xl);
  }

  .mission-content {
    max-width: 900px;
  }

  .mission-content h2 {
    margin-block-end: var(--space-xl);
    max-width: 700px;
  }

  .mission-columns {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    margin-block-end: var(--space-xl);
  }

  @media (min-width: 768px) {
    .mission-columns {
      grid-template-columns: 1fr 1fr;
    }
  }

  .mission-columns p {
    color: var(--color-charcoal);
    opacity: 0.8;
    line-height: 1.7;
    margin-block-end: var(--space-md);
  }

  .pull-quote {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-style: italic;
    color: var(--color-orange);
    border-inline-start: 4px solid var(--color-gold);
    padding-inline-start: var(--space-lg);
    margin-block-start: var(--space-lg);
  }

  /* ===== Values ===== */
  .about-values {
    background: var(--color-green-sage);
    padding-block: var(--space-2xl);
  }

  .values-header {
    text-align: center;
    margin-block-end: var(--space-xl);
  }

  .values-header .section-label {
    color: var(--color-charcoal);
    opacity: 0.7;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-lg);
  }

  .value-card {
    background: var(--color-cream-light);
    border-radius: 12px;
    padding: var(--space-xl) var(--space-lg);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-medium), box-shadow var(--transition-medium);
    animation-delay: var(--stagger);
  }

  .value-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .value-icon {
    display: block;
    font-size: 2rem;
    color: var(--color-orange);
    margin-block-end: var(--space-sm);
  }

  .value-card h3 {
    margin-block-end: var(--space-xs);
  }

  .value-card p {
    font-size: var(--text-sm);
    color: var(--color-charcoal);
    opacity: 0.75;
    line-height: 1.7;
  }

  /* ===== Theory of Change ===== */
  .about-toc {
    background: var(--color-cream);
    padding-block: var(--space-2xl);
  }

  .about-toc h2 {
    margin-block-end: var(--space-xl);
  }

  .toc-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 768px) {
    .toc-steps {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-lg);
    }
  }

  .toc-step {
    position: relative;
    animation-delay: var(--stagger);
  }

  .step-number {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: 900;
    color: var(--color-orange);
    opacity: 0.3;
    line-height: 1;
    margin-block-end: var(--space-sm);
  }

  .step-connector {
    display: none;
  }

  @media (min-width: 768px) {
    .step-connector {
      display: block;
      position: absolute;
      top: 2rem;
      right: calc(-1 * var(--space-lg) / 2 - 20px);
      width: 40px;
      height: 2px;
      background: linear-gradient(to right, var(--color-orange), transparent);
    }

    .toc-step:last-child .step-connector {
      display: none;
    }
  }

  .toc-step h3 {
    color: var(--color-charcoal);
    margin-block-end: var(--space-xs);
  }

  .toc-step p {
    font-size: var(--text-sm);
    color: var(--color-charcoal);
    opacity: 0.75;
    line-height: 1.7;
  }

  /* ===== Community ===== */
  .about-community {
    background: var(--color-charcoal);
    padding-block: var(--space-2xl);
  }

  .community-content {
    text-align: center;
    max-width: 640px;
  }

  .community-content h2 {
    color: var(--color-cream);
    margin-block-end: var(--space-md);
  }

  .community-content > p {
    color: var(--color-cream);
    opacity: 0.8;
    font-size: var(--text-lg);
    line-height: 1.7;
    margin-block-end: var(--space-xl);
    margin-inline: auto;
  }

  .community-links {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .community-link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.7em 1.5em;
    border: 1px solid rgba(237, 221, 200, 0.2);
    border-radius: 50px;
    color: var(--color-cream);
    font-weight: 500;
    font-size: var(--text-sm);
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast),
      transform var(--transition-fast),
      color var(--transition-fast);
    text-decoration: none;
  }

  .community-link:hover {
    background: var(--color-orange);
    border-color: var(--color-orange);
    color: var(--color-cream);
    transform: translateY(-2px);
  }

  .link-icon {
    font-size: 1.2em;
  }
</style>
