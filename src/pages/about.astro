---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import SectionDivider from '../components/SectionDivider.astro';

const values = [
  {
    icon: '&#9878;',
    title: 'Power Transformation',
    description: 'Shifting power from centralized entities to communities through participatory governance and decentralized coordination. Rewiring how resources and authority flow through society.',
  },
  {
    icon: '&#10047;',
    title: 'Systems Innovation',
    description: 'Researching and incubating initiatives that harness emerging technologies and practices for decentralized coordination in pursuit of systems transformation.',
  },
  {
    icon: '&#9733;',
    title: 'Open Source Commons',
    description: 'Creating and sharing open-source playbooks that enable others to replicate and build upon governance models in their own contexts. Built to be forked.',
  },
  {
    icon: '&#10070;',
    title: 'Community Weaving',
    description: 'Cultivating the connective tissue between disparate communities, initiatives, technologies, and bioregions. Fostering collaboration and the exchange of knowledge and resources.',
  },
];

const steps = [
  { label: 'Invention', description: 'Researching and incubating new models for decentralized governance, community currencies, and solidarity infrastructure - testing what works at the grassroots level.' },
  { label: 'Investment', description: 'Mobilizing capital in collectively intelligent, distributed, and equitable ways that prioritize community-led initiatives and regenerative outcomes.' },
  { label: 'Acceleration', description: 'Creating the social and financial flywheels that enable these models to scale - weaving networks, sharing playbooks, and strengthening collective capacity.' },
];
---

<BaseLayout
  title="About — SuperBenefit"
  description="A node in the regenerative ecosystem, harnessing web3 and AI to shift power and to grow new systems of coordination: open source, peer-to-peer, built to be forked."
>
  <!-- About Hero -->
  <section class="about-hero">
    <div class="about-hero-overlay"></div>
    <div class="container about-hero-content">
      <h1>About SuperBenefit</h1>
      <p class="about-hero-sub">A node in the regenerative ecosystem</p>
    </div>
  </section>

  <SectionDivider from="charcoal" to="cream" />

  <!-- Mission Section -->
  <section class="about-mission">
    <div class="container mission-content" data-animate="fade-up">
      <span class="section-label">Our Mission</span>
      <h2>Emerging technologies are a rare opportunity. Not a silver bullet, but the potential to intervene at the deepest levels of how power flows.</h2>
      <div class="mission-columns">
        <div>
          <p>
            Our current systems of coordination - how we organize, allocate resources, govern ourselves, make collective decisions - clearly aren't working for most people. Value is extracted rather than circulated, power ever more concentrated, our planet and people devastated.
          </p>
          <p>
            Meanwhile, across the world, there is a hidden mosaic of grassroots initiatives yearning to be woven. Open source, peer-to-peer, built to be forked.
          </p>
        </div>
        <div>
          <p>
            SuperBenefit is one part of a much larger regenerative ecosystem. Together, we are building the commons and cultivating the connective tissue between disparate communities, initiatives, technologies, and bioregions.
          </p>
          <p>
            Through projects like the <a href="https://knowledge.superbenefit.dev/docs/" target="_blank" rel="noopener noreferrer">Reimagining Power Project</a> and <a href="https://www.allinforsport.org/" target="_blank" rel="noopener noreferrer">All In For Sport</a>, we work alongside partners across multiple continents, experimenting with decentralized tools to shift ownership and agency to communities that have been excluded from the systems that shape their lives.
          </p>
        </div>
      </div>
      <blockquote class="pull-quote">
        "Not just reimagining existing systems, but growing new ones alongside them."
      </blockquote>
    </div>
  </section>

  <SectionDivider from="cream" to="charcoal" />

  {/* Values, Theory of Change, and Community sections hidden until content is properly written */}
</BaseLayout>

<style>
  /* ===== About Hero ===== */
  .about-hero {
    position: relative;
    background: var(--color-charcoal);
    background-image: url('/images/brand-showcase.webp');
    background-size: cover;
    background-position: center;
    padding-block-start: calc(var(--header-height) + var(--space-2xl));
    padding-block-end: var(--space-2xl);
    min-height: 50vh;
    display: flex;
    align-items: flex-end;
  }

  .about-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(245, 135, 44, 0.7) 0%,
      rgba(196, 64, 26, 0.8) 50%,
      rgba(45, 45, 45, 0.95) 100%
    );
  }

  .about-hero-content {
    position: relative;
    z-index: 1;
  }

  .about-hero h1 {
    color: var(--color-cream);
    font-size: var(--text-3xl);
    margin-block-end: var(--space-xs);
  }

  .about-hero-sub {
    color: var(--color-cream);
    opacity: 0.8;
    font-size: var(--text-xl);
    font-family: var(--font-serif);
    font-style: italic;
  }

  /* ===== Section Label ===== */
  .section-label {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-orange);
    margin-block-end: var(--space-sm);
  }

  /* ===== Mission ===== */
  .about-mission {
    background: var(--color-cream);
    padding-block: var(--space-2xl);
  }

  .mission-content {
    max-width: 900px;
  }

  .mission-content h2 {
    margin-block-end: var(--space-xl);
    max-width: 700px;
  }

  .mission-columns {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    margin-block-end: var(--space-xl);
  }

  @media (min-width: 768px) {
    .mission-columns {
      grid-template-columns: 1fr 1fr;
    }
  }

  .mission-columns p {
    color: var(--color-charcoal);
    opacity: 0.8;
    line-height: 1.7;
    margin-block-end: var(--space-md);
  }

  .mission-columns a {
    color: var(--color-orange);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: opacity var(--transition-fast);
  }

  .mission-columns a:hover {
    opacity: 0.7;
  }

  .pull-quote {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-style: italic;
    color: var(--color-orange);
    border-inline-start: 4px solid var(--color-gold);
    padding-inline-start: var(--space-lg);
    margin-block-start: var(--space-lg);
  }

  /* ===== Values ===== */
  .about-values {
    background: var(--color-green-sage);
    padding-block: var(--space-2xl);
  }

  .values-header {
    text-align: center;
    margin-block-end: var(--space-xl);
  }

  .values-header .section-label {
    color: var(--color-charcoal);
    opacity: 0.7;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-lg);
  }

  .value-card {
    background: var(--color-cream-light);
    border-radius: 12px;
    padding: var(--space-xl) var(--space-lg);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-medium), box-shadow var(--transition-medium);
    animation-delay: var(--stagger);
  }

  .value-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .value-icon {
    display: block;
    font-size: 2rem;
    color: var(--color-orange);
    margin-block-end: var(--space-sm);
  }

  .value-card h3 {
    margin-block-end: var(--space-xs);
  }

  .value-card p {
    font-size: var(--text-sm);
    color: var(--color-charcoal);
    opacity: 0.75;
    line-height: 1.7;
  }

  /* ===== Theory of Change ===== */
  .about-toc {
    background: var(--color-cream);
    padding-block: var(--space-2xl);
  }

  .about-toc h2 {
    margin-block-end: var(--space-xl);
  }

  .toc-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 768px) {
    .toc-steps {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-lg);
    }
  }

  .toc-step {
    position: relative;
    animation-delay: var(--stagger);
  }

  .step-number {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: 900;
    color: var(--color-orange);
    opacity: 0.3;
    line-height: 1;
    margin-block-end: var(--space-sm);
  }

  .step-connector {
    display: none;
  }

  @media (min-width: 768px) {
    .step-connector {
      display: block;
      position: absolute;
      top: 2rem;
      right: calc(-1 * var(--space-lg) / 2 - 20px);
      width: 40px;
      height: 2px;
      background: linear-gradient(to right, var(--color-orange), transparent);
    }

    .toc-step:last-child .step-connector {
      display: none;
    }
  }

  .toc-step h3 {
    color: var(--color-charcoal);
    margin-block-end: var(--space-xs);
  }

  .toc-step p {
    font-size: var(--text-sm);
    color: var(--color-charcoal);
    opacity: 0.75;
    line-height: 1.7;
  }

  /* ===== Community ===== */
  .about-community {
    background: var(--color-charcoal);
    padding-block: var(--space-2xl);
  }

  .community-content {
    text-align: center;
    max-width: 640px;
  }

  .community-content h2 {
    color: var(--color-cream);
    margin-block-end: var(--space-md);
  }

  .community-content > p {
    color: var(--color-cream);
    opacity: 0.8;
    font-size: var(--text-lg);
    line-height: 1.7;
    margin-block-end: var(--space-xl);
    margin-inline: auto;
  }

  .community-links {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .community-link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.7em 1.5em;
    border: 1px solid rgba(237, 221, 200, 0.2);
    border-radius: 50px;
    color: var(--color-cream);
    font-weight: 500;
    font-size: var(--text-sm);
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast),
      transform var(--transition-fast),
      color var(--transition-fast);
    text-decoration: none;
  }

  .community-link:hover {
    background: var(--color-orange);
    border-color: var(--color-orange);
    color: var(--color-cream);
    transform: translateY(-2px);
  }

  .link-icon {
    font-size: 1.2em;
  }
</style>
