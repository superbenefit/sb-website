---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogList from '../../components/BlogList.astro';
import PageHero from '../../components/PageHero.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import CallToAction from '../../components/CallToAction.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection('updates', ({ data }) => !data.draft);
  const sortedPosts = allPosts.sort(
    (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
  );
  return paginate(sortedPosts, { pageSize: 10 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

const hero = {
  title: 'Updates',
  subtitle: 'Notes on governance, DAOs, and the frontiers of systems innovation',
  overlayGradient: `linear-gradient(
    to bottom,
    color-mix(in srgb, var(--color-green-sage) 30%, transparent) 0%,
    color-mix(in srgb, var(--color-charcoal) 60%, transparent) 50%,
    color-mix(in srgb, var(--color-charcoal) 95%, transparent) 100%
  )`,
  showStars: true,
};
---

<BaseLayout
  title={page.currentPage === 1 ? 'Updates — SuperBenefit' : `Updates — Page ${page.currentPage} — SuperBenefit`}
  description="Notes on governance, DAOs, web3, and building a better world through systems innovation."
>
  <PageHero {...hero} />

  <SectionDivider from="black" to="cream" />

  <section class="updates-content">
    <div class="container">
      <BlogList posts={page.data} />

      {page.lastPage > 1 && (
        <nav class="pagination" aria-label="Updates pagination">
          {page.url.prev && (
            <a href={page.url.prev} class="pagination-btn">← Newer</a>
          )}
          <span class="pagination-info">Page {page.currentPage} of {page.lastPage}</span>
          {page.url.next && (
            <a href={page.url.next} class="pagination-btn">Older →</a>
          )}
        </nav>
      )}
    </div>
  </section>

  <SectionDivider from="cream" to="charcoal" />

  <CallToAction />
</BaseLayout>

<style>
  .updates-content {
    background: var(--color-cream);
    padding-block: var(--space-2xl);
  }

  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
    padding-block-start: var(--space-xl);
    border-top: 1px solid rgb(var(--color-black-rgb) / 0.1);
    margin-block-start: var(--space-xl);
  }

  .pagination-btn {
    display: inline-block;
    padding: 0.6em 1.4em;
    background: var(--color-black);
    color: var(--color-cream);
    font-weight: 600;
    font-size: var(--text-sm);
    border-radius: 6px;
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }

  .pagination-btn:hover { opacity: 0.8; }

  .pagination-info {
    font-size: var(--text-sm);
    color: var(--color-black);
    opacity: 0.6;
  }
</style>
