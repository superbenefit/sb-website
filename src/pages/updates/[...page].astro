---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogList from '../../components/BlogList.astro';
import PageHero from '../../components/PageHero.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import CallToAction from '../../components/CallToAction.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection('updates', ({ data }) => !data.draft);
  const sortedPosts = allPosts.sort(
    (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
  );
  return paginate(sortedPosts, { pageSize: 10 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

// Draft mode: page renders fully in dev, "Coming soon" placeholder in production.
// Toggle by flipping `pageIsDraft` to false when the page is ready to ship.
const pageIsDraft = true;
const showDraftPlaceholder = pageIsDraft && import.meta.env.PROD;

const hero = {
  title: 'Updates',
  subtitle: 'Notes on governance, DAOs, and the frontiers of systems innovation',
  overlayGradient: `linear-gradient(
    to bottom,
    color-mix(in srgb, var(--color-green-sage) 30%, transparent) 0%,
    color-mix(in srgb, var(--color-charcoal) 60%, transparent) 50%,
    color-mix(in srgb, var(--color-charcoal) 95%, transparent) 100%
  )`,
  showStars: true,
};
---

<BaseLayout
  title={page.currentPage === 1 ? 'Updates — SuperBenefit' : `Updates — Page ${page.currentPage} — SuperBenefit`}
  description="Notes on governance, DAOs, web3, and building a better world through systems innovation."
  noindex={showDraftPlaceholder}
>
  {!showDraftPlaceholder && (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://superbenefit.org/' },
          { '@type': 'ListItem', position: 2, name: 'Updates', item: 'https://superbenefit.org/updates/' },
          ...(page.currentPage > 1
            ? [
                {
                  '@type': 'ListItem',
                  position: 3,
                  name: `Page ${page.currentPage}`,
                  item: `https://superbenefit.org/updates/${page.currentPage === 2 ? '' : page.currentPage + '/'}`,
                },
              ]
            : []),
        ],
      })}
    />
  )}
  {showDraftPlaceholder ? (
    <section class="draft-placeholder">
      <div class="container">
        <span class="section-label">Draft</span>
        <h1>Coming soon</h1>
        <p>We're working on this page. Check back soon.</p>
        <a href="/" class="draft-cta">Back to home</a>
      </div>
    </section>
  ) : (
    <>
      <PageHero {...hero} />

  <SectionDivider from="black" to="cream" />

  <section class="updates-content">
    <div class="container">
      <BlogList posts={page.data} />

      {page.lastPage > 1 && (
        <nav class="pagination" aria-label="Updates pagination">
          {page.url.prev && (
            <a href={page.url.prev} class="pagination-btn">← Newer</a>
          )}
          <span class="pagination-info">Page {page.currentPage} of {page.lastPage}</span>
          {page.url.next && (
            <a href={page.url.next} class="pagination-btn">Older →</a>
          )}
        </nav>
      )}
    </div>
  </section>

  <SectionDivider from="cream" to="charcoal" />

      <CallToAction />
    </>
  )}
</BaseLayout>

<style>
  /* ===== Draft placeholder (production only, when pageIsDraft === true) ===== */
  .draft-placeholder {
    background: var(--color-cream);
    padding-block: var(--space-2xl);
    min-height: 60vh;
    display: flex;
    align-items: center;
    text-align: center;
  }
  .draft-placeholder .container {
    max-width: 640px;
  }
  .draft-placeholder .section-label {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-orange);
    margin-block-end: var(--space-sm);
  }
  .draft-placeholder h1 {
    font-family: var(--font-serif);
    color: var(--color-charcoal);
    margin-block-end: var(--space-md);
  }
  .draft-placeholder p {
    color: var(--color-charcoal);
    opacity: 0.8;
    font-size: var(--text-lg);
    line-height: 1.7;
    margin-block-end: var(--space-xl);
  }
  .draft-cta {
    display: inline-block;
    padding: 0.9em 2em;
    border-radius: 50px;
    background: var(--color-orange);
    color: var(--color-cream);
    font-weight: 600;
    text-decoration: none;
    transition: background var(--transition-fast);
  }
  .draft-cta:hover {
    background: var(--color-orange-dark);
  }

  .updates-content {
    background: var(--color-cream);
    padding-block: var(--space-2xl);
  }

  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
    padding-block-start: var(--space-xl);
    border-top: 1px solid rgb(var(--color-black-rgb) / 0.1);
    margin-block-start: var(--space-xl);
  }

  .pagination-btn {
    display: inline-block;
    padding: 0.6em 1.4em;
    background: var(--color-black);
    color: var(--color-cream);
    font-weight: 600;
    font-size: var(--text-sm);
    border-radius: 6px;
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }

  .pagination-btn:hover { opacity: 0.8; }

  .pagination-info {
    font-size: var(--text-sm);
    color: var(--color-black);
    opacity: 0.6;
  }
</style>
