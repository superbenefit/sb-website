---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { sanitizeHtml } from '../../utils/sanitize';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;

const formattedDate = post.data.publishedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={`${post.data.title} — SuperBenefit Blog`}
  description={post.data.excerpt || ''}
  ogImage={post.data.coverImage}
  type="article"
  publishedAt={post.data.publishedAt}
>
  <article class="blog-post" transition:name={`blog-${post.id}`}>
    {post.data.coverImage && (
      <div class="post-cover">
        <img src={post.data.coverImage} alt={post.data.title} />
      </div>
    )}

    <div class="container post-container">
      <header class="post-header">
        <div class="post-meta">
          <time datetime={post.data.publishedAt.toISOString()}>{formattedDate}</time>
          {post.data.tags.length > 0 && (
            <div class="post-tags">
              {post.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
        <h1>{post.data.title}</h1>
        {post.data.author && (
          <div class="post-author">
            <span>by {post.data.author.name}</span>
          </div>
        )}
      </header>

      <div class="prose" set:html={sanitizeHtml(post.data.content)} />

      <footer class="post-footer">
        <a href="/blog" class="back-link">&larr; Back to all posts</a>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    padding-block-start: var(--header-height);
  }

  .post-cover {
    width: 100%;
    max-height: 420px;
    overflow: hidden;
  }

  .post-cover img {
    width: 100%;
    height: 420px;
    object-fit: cover;
  }

  .post-container {
    max-width: 760px;
    padding-block: var(--space-xl) var(--space-2xl);
  }

  .post-header {
    margin-block-end: var(--space-xl);
    padding-block-end: var(--space-lg);
    border-block-end: 1px solid rgba(0, 0, 0, 0.08);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-block-end: var(--space-md);
  }

  .post-meta time {
    font-size: var(--text-xs);
    color: var(--color-orange);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .post-tags {
    display: flex;
    gap: var(--space-xs);
  }

  .tag {
    display: inline-block;
    font-size: var(--text-xs);
    padding: 0.2em 0.7em;
    background: rgba(122, 154, 78, 0.15);
    color: var(--color-green);
    border-radius: 50px;
    font-weight: 500;
  }

  .post-header h1 {
    font-size: var(--text-3xl);
    margin-block-end: var(--space-sm);
  }

  .post-author {
    font-size: var(--text-sm);
    color: var(--color-charcoal);
    opacity: 0.6;
  }

  .post-footer {
    margin-block-start: var(--space-2xl);
    padding-block-start: var(--space-lg);
    border-block-start: 1px solid rgba(0, 0, 0, 0.08);
  }

  .back-link {
    font-weight: 600;
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
</style>
