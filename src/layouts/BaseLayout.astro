---
import { ClientRouter } from 'astro:transitions';
import { Font } from 'astro:assets';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FooterFade from '../components/FooterFade.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';
import '../styles/animations.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  bodyClass?: string;
  type?: 'website' | 'article';
  publishedAt?: Date;
  noindex?: boolean;
  authorName?: string;
  authorUrl?: string;
  coverImage?: string;
  dateModified?: Date;
  /**
   * Origins to preconnect to from the document <head>. Should be limited to
   * pages that actually fetch resources from these origins — emitting
   * preconnects on every page triggers a "Unused preconnect" Lighthouse
   * warning and wastes connection setup time on pages that don't need it.
   */
  preconnect?: string[];
}

const {
  title,
  description,
  ogImage,
  bodyClass = '',
  type,
  publishedAt,
  noindex = false,
  authorName,
  authorUrl,
  coverImage,
  dateModified,
  preconnect = [],
} = Astro.props;

const siteUrl = Astro.site?.href ?? 'https://superbenefit.org/';
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${siteUrl}#organization`,
  name: 'SuperBenefit',
  url: siteUrl,
  description: 'A node in the regenerative ecosystem, harnessing web3 and AI to shift power and to grow new systems of coordination: open source, peer-to-peer, built to be forked.',
  logo: new URL('/images/superbenefit-logo.webp', Astro.site).href,
  sameAs: [
    'https://discord.gg/q95fFXGu67',
    'https://github.com/superbenefit',
    'https://twitter.com/SuperBenefitDAO',
    'https://knowledge.superbenefit.org',
    'https://paragraph.com/@superbenefit-2',
  ],
};

const isHomepage = Astro.url.pathname === '/';
const websiteSchema = isHomepage
  ? {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      '@id': `${siteUrl}#website`,
      name: 'SuperBenefit',
      url: siteUrl,
      description: 'A node in the regenerative ecosystem, harnessing web3 and AI to shift power and to grow new systems of coordination: open source, peer-to-peer, built to be forked.',
      publisher: { '@id': `${siteUrl}#organization` },
      potentialAction: {
        '@type': 'SearchAction',
        target: `${siteUrl}updates?q={search_term_string}`,
        'query-input': 'required name=search_term_string',
      },
    }
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO title={title} description={description} ogImage={ogImage} type={type} publishedAt={publishedAt} noindex={noindex} authorName={authorName} authorUrl={authorUrl} coverImage={coverImage} dateModified={dateModified} />
    <link rel="manifest" href="/manifest.json" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {preconnect.map((origin) => <link rel="preconnect" href={origin} />)}
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    {websiteSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />}
    <Font cssVariable="--font-playfair" preload />
    <Font cssVariable="--font-inter" preload />
    <ClientRouter />
  </head>
  <body class={bodyClass}>
    <Header />
    <main>
      <slot />
    </main>
    <FooterFade />
    <Footer />
    <script>
      import { isNavLinkActive } from '../utils/nav';

      function updateNavActive() {
        const path = window.location.pathname;

        function setActive(link: HTMLAnchorElement) {
          const href = link.getAttribute('href');
          if (!href || href.startsWith('http')) return;
          const isActive = isNavLinkActive(path, href);
          link.classList.toggle('active', isActive);
          if (isActive) {
            link.setAttribute('aria-current', 'page');
          } else {
            link.removeAttribute('aria-current');
          }
        }

        // Links inside .site-nav (nav links + mobile contact CTA)
        document.querySelectorAll<HTMLAnchorElement>('.site-nav a').forEach(setActive);

        // Desktop contact CTA (outside .site-nav, inside .header-inner)
        document.querySelectorAll<HTMLAnchorElement>('.header-cta').forEach(setActive);
      }
      document.addEventListener('astro:page-load', updateNavActive);

      // Handle hash-based scrolling after view transitions.
      // When navigating to /#section-id from another page, Astro's
      // ClientRouter swaps the page content but may not scroll to the
      // hash target. This ensures the section is scrolled into view.
      function scrollToHash() {
        const hash = window.location.hash;
        if (hash) {
          const el = document.querySelector(hash);
          if (el) {
            // Small delay to ensure DOM is settled after view transition
            setTimeout(() => {
              el.scrollIntoView({ behavior: 'smooth' });
            }, 100);
          }
        }
      }
      document.addEventListener('astro:after-swap', scrollToHash);
      // Also run on initial page load (e.g., direct link with hash)
      scrollToHash();
    </script>
  </body>
</html>

<style>
  main {
    min-height: 100vh;
  }
</style>
