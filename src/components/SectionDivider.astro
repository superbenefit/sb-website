---
interface GradientStop {
  offset: string;
  color: string;
}

interface GradientDef {
  angle?: number;
  stops: GradientStop[];
}

interface Props {
  from: 'cream' | 'charcoal' | 'green' | 'orange' | 'black';
  to: 'cream' | 'charcoal' | 'green' | 'orange' | 'black';
  gradient?: GradientDef;
}

const colorMap: Record<string, string> = {
  cream: 'var(--color-cream)',
  charcoal: 'var(--color-charcoal)',
  green: 'var(--color-green-sage)',
  orange: 'var(--color-orange)',
  black: 'var(--color-black)',
};

const { from, to, gradient } = Astro.props;
const fromColor = colorMap[from];
const toColor = colorMap[to];
const gradientId = `section-divider-gradient-${Math.random().toString(36).slice(2, 9)}`;
const fill = gradient ? `url(#${gradientId})` : 'var(--to)';

// SVG y-axis points down, while CSS linear-gradient angles are clockwise from up,
// so we flip the angle around the vertical axis to keep the same visual direction.
const svgAngle = gradient?.angle != null
  ? (180 - gradient.angle + 360) % 360
  : null;
---

<div
  class="section-divider"
  style={`--from: ${fromColor}; --to: ${toColor};`}
  aria-hidden="true"
>
  <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    {
      gradient && (
        <defs>
          <linearGradient
            id={gradientId}
            x1="0"
            y1="0"
            x2="0"
            y2="1"
            gradientUnits="objectBoundingBox"
            gradientTransform={svgAngle != null ? `rotate(${svgAngle} 0.5 0.5)` : undefined}
          >
            {gradient.stops.map((stop) => (
              <stop offset={stop.offset} stop-color={stop.color} />
            ))}
          </linearGradient>
        </defs>
      )
    }
    <path d="M0,0 C360,80 1080,0 1440,60 L1440,80 L0,80 Z" fill={fill} />
  </svg>
</div>

<style>
  .section-divider {
    position: relative;
    height: 60px;
    margin-top: -60px;
    line-height: 0;
    transform: scaleY(1.02);
    transform-origin: bottom;
  }

  .section-divider svg {
    display: block;
    width: 100%;
    height: 60px;
  }

  @media (min-width: 768px) {
    .section-divider {
      height: 80px;
      margin-top: -80px;
      transform: scaleY(1.02);
      transform-origin: bottom;
    }

    .section-divider svg {
      height: 80px;
    }
  }
</style>
