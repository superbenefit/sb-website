---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
  type?: 'website' | 'article';
  publishedAt?: Date;
  noindex?: boolean;
  authorName?: string;
  authorUrl?: string;
  coverImage?: string;
  dateModified?: Date;
}

const {
  title,
  description,
  ogImage = '/images/brand-showcase.webp',
  canonicalUrl,
  type = 'website',
  publishedAt,
  noindex = false,
  authorName,
  authorUrl,
  coverImage,
  dateModified,
} = Astro.props;

const siteName = 'SuperBenefit';
const fullTitle = title.includes(siteName) ? title : `${title} — ${siteName}`;

// Build canonical from Astro.url.pathname (not href) to strip query strings
// and tracking parameters. Falls back to Astro.site if pathname is empty.
const siteUrl = Astro.site?.href ?? 'https://superbenefit.org/';
const finalCanonical = canonicalUrl
  ? canonicalUrl
  : `${siteUrl.replace(/\/$/, '')}${Astro.url.pathname}`;

// OG image must be absolute; resolve relative paths against site.
const resolvedOgImage = new URL(ogImage, Astro.site).href;
const resolvedCoverImage = coverImage ? new URL(coverImage, Astro.site).href : undefined;

// Brand showcase image is 1200x630.
const ogImageWidth = 1200;
const ogImageHeight = 630;
const ogImageAlt = `${siteName} — regenerative coordination, open source, peer-to-peer`;
const ogLocale = 'en_US';

// BlogPosting schema for articles (extended with author, image, dateModified,
// mainEntityOfPage). Organization is injected by BaseLayout — do not duplicate.
const articleSchema =
  type === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description: description,
        url: finalCanonical,
        mainEntityOfPage: { '@type': 'WebPage', '@id': finalCanonical },
        ...(authorName && {
          author: authorUrl
            ? { '@type': 'Person', name: authorName, url: authorUrl }
            : { '@type': 'Person', name: authorName },
        }),
        ...(resolvedCoverImage && { image: resolvedCoverImage }),
        ...(publishedAt && { datePublished: publishedAt.toISOString() }),
        ...(dateModified && { dateModified: dateModified.toISOString() }),
        publisher: {
          '@type': 'Organization',
          name: siteName,
          logo: { '@type': 'ImageObject', url: new URL('/images/superbenefit-logo.webp', Astro.site).href },
        },
      }
    : null;
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
<link rel="canonical" href={finalCanonical} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" href="/favicon.svg" />
<meta name="theme-color" content="#1a1a1a" />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={resolvedOgImage} />
<meta property="og:image:secure_url" content={resolvedOgImage} />
<meta property="og:image:width" content={String(ogImageWidth)} />
<meta property="og:image:height" content={String(ogImageHeight)} />
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:url" content={finalCanonical} />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content={ogLocale} />
{publishedAt && <meta property="article:published_time" content={publishedAt.toISOString()} />}
{dateModified && <meta property="article:modified_time" content={dateModified.toISOString()} />}
{authorName && <meta property="article:author" content={authorName} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={resolvedOgImage} />
<meta name="twitter:image:alt" content={ogImageAlt} />

<!-- JSON-LD: BlogPosting for articles only. Organization is emitted by BaseLayout. -->
{articleSchema && (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
)}
