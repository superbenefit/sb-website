        </div>
      </div>
    </div>

    <div class="footer-right">
      <a href="https://ethereum.org" target="_blank" rel="noopener noreferrer" class="footer-badge">
        <img src="/images/built-on-ethereum.webp" alt="Built on Ethereum" width="160" height="48" loading="lazy" />
      </a>
    </div>
  </div>
  <div class="footer-rainbow"></div>
  <p class="footer-copy container">&copy; {year} SuperBenefit, a Worker Self-Directed Non-Profit DAO LLC</p>
</footer>

<style>
  .site-footer {
    position: relative;
    background: var(--color-black);
    color: var(--color-cream);
    padding-block-start: var(--space-xl);
    overflow: hidden;
  }

  .footer-stars {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(1px 1px at 10% 20%, rgba(255,255,255,0.6), transparent),
      radial-gradient(1px 1px at 30% 60%, rgba(255,255,255,0.4), transparent),
      radial-gradient(1.5px 1.5px at 50% 10%, rgba(255,255,255,0.7), transparent),
      radial-gradient(1px 1px at 70% 40%, rgba(255,255,255,0.5), transparent),
      radial-gradient(1px 1px at 90% 80%, rgba(255,255,255,0.4), transparent),
      radial-gradient(1.5px 1.5px at 15% 85%, rgba(255,255,255,0.6), transparent),
      radial-gradient(1px 1px at 85% 15%, rgba(255,255,255,0.5), transparent),
      radial-gradient(1px 1px at 45% 75%, rgba(255,255,255,0.3), transparent),
      radial-gradient(1.5px 1.5px at 65% 55%, rgba(255,255,255,0.5), transparent),
      radial-gradient(1px 1px at 25% 35%, rgba(255,255,255,0.4), transparent);
    pointer-events: none;
    opacity: 0.5;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: end;
    position: relative;
  }

  /* Left column — brand + social inline */
  .footer-left {
    display: flex;
    flex-direction: column;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .footer-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
  }

  .footer-name {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .footer-social {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-inline-start: var(--space-md);
  }

  .footer-social a {
    color: var(--color-cream);
    opacity: 0.6;
    transition: opacity var(--transition-fast), color var(--transition-fast), transform var(--transition-fast);
  }

  .footer-social a:hover {
    opacity: 1;
    color: var(--color-orange);
    transform: translateY(-2px);
  }

  /* Right column — Ethereum badge */
  .footer-right {
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
  }

  .footer-badge {
    display: block;
    opacity: 0.7;
    transition: opacity var(--transition-fast);
  }

  .footer-badge:hover {
    opacity: 1;
  }

  .footer-badge img {
    display: block;
    height: 48px;
    width: auto;
  }

  .footer-rainbow {
    height: 3px;
    background: var(--gradient-rainbow);
    margin-block-start: var(--space-xl);
  }

  .footer-copy {
    font-size: var(--text-xs);
    color: var(--color-cream);
    opacity: 0.35;
    padding-block: var(--space-md);
    line-height: 1.4;
    text-align: center;
  }

  /* Mobile: stack to single column */
  @media (max-width: 640px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .footer-right {
      align-items: flex-start;
    }
  }
</style>
