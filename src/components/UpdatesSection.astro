---
/**
 * UpdatesSection — cream section showing the 3 most recent posts from
 * the SuperBenefit Updates feed. Sits between ExternalServices and CallToAction.
 */
import { getCollection } from 'astro:content';
import BlogCard from './BlogCard.astro';

const allPosts = await getCollection('updates', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);
---

<section class="updates-section">
  <div class="container">
    <header class="updates-header" data-animate="fade-up">
      <span class="updates-label">Updates</span>
      <h2>Recent Writing</h2>
      <p>Notes on governance, DAOs, and the frontiers of systems innovation.</p>
    </header>

    {recentPosts.length > 0 ? (
      <div class="updates-grid">
        {recentPosts.map((post, i) => (
          <div class="updates-card-wrap" data-animate="fade-up" style={`--stagger: ${i * 100}ms`}>
            <BlogCard
              id={post.id}
              title={post.data.title}
              excerpt={post.data.excerpt}
              publishedAt={post.data.publishedAt}
              tags={post.data.tags}
              coverImage={post.data.coverImage}
            />
          </div>
        ))}
      </div>
    ) : (
      <div class="updates-empty" data-animate="fade-up">
        <p>Coming soon &mdash; check back for writing on governance, DAOs, and systems innovation.</p>
      </div>
    )}

    <footer class="updates-footer" data-animate="fade-up">
      <a href="/updates" class="updates-more">
        View all updates
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"></path><polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </footer>
  </div>
</section>

<style>
  .updates-section {
    background: linear-gradient(
      168deg,
      var(--color-cream) 0%,
      var(--color-cream-light) 50%,
      var(--color-cream) 100%
    );
    padding-block: var(--space-2xl);
    position: relative;
    overflow: hidden;
  }

  /* Header */
  .updates-header { text-align: center; margin-block-end: var(--space-2xl); }
  .updates-label {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-orange);
    margin-block-end: var(--space-sm);
  }
  .updates-header h2 {
    font-size: var(--text-2xl);
    color: var(--color-charcoal);
    margin-block-end: var(--space-sm);
  }
  .updates-header p {
    font-size: var(--text-base);
    color: var(--color-charcoal);
    opacity: 0.6;
    margin-inline: auto;
    max-width: 48ch;
  }

  /* Grid */
  .updates-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }
  @media (min-width: 640px) { .updates-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .updates-grid { grid-template-columns: repeat(3, 1fr); } }
  .updates-card-wrap { animation-delay: var(--stagger); }

  /* Empty state */
  .updates-empty {
    text-align: center;
    padding-block: var(--space-xl);
    color: var(--color-charcoal);
    opacity: 0.5;
    font-style: italic;
    font-size: var(--text-lg);
  }

  /* Footer */
  .updates-footer { text-align: center; margin-block-start: var(--space-xl); }
  .updates-more {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-orange);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: opacity var(--transition-fast);
  }
  .updates-more:hover { opacity: 0.7; }
</style>
