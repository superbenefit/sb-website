---

<section class="cta">
  <div class="container cta-inner" data-animate="fade-up">
    <h2>Work With Us</h2>
    <p>
      Our capacity grows from our network, and we welcome values-aligned collaborators of all sorts.
    </p>
    <div class="cta-buttons">
      <a href="https://discord.gg/superbenefit" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
        Get Involved
      </a>
      <a href="/about" class="btn btn-ghost">
        Learn More
      </a>
    </div>
  </div>
</section>

<style>
  .cta {
    background: var(--color-orange);
    padding-block: 140px var(--space-2xl);
    position: relative;
    overflow: hidden;
  }

  .cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(196, 64, 26, 0.3), transparent 60%),
      radial-gradient(ellipse at 80% 30%, rgba(212, 168, 67, 0.2), transparent 50%);
    pointer-events: none;
  }

  .cta-inner {
    position: relative;
    text-align: center;
    max-width: 640px;
  }

  .cta h2 {
    color: var(--color-cream);
    font-size: var(--text-3xl);
    margin-block-end: var(--space-md);
  }

  .cta p {
    color: var(--color-cream);
    opacity: 0.9;
    font-size: var(--text-lg);
    line-height: 1.7;
    margin-block-end: var(--space-xl);
    margin-inline: auto;
  }

  .cta-buttons {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.9em 2em;
    border-radius: 50px;
    font-weight: 600;
    font-size: var(--text-base);
    letter-spacing: 0.02em;
    transition:
      transform var(--transition-fast),
      box-shadow var(--transition-fast),
      background-color var(--transition-fast);
    text-decoration: none;
  }

  .btn-primary {
    background: var(--color-charcoal);
    color: var(--color-cream);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.3);
    color: var(--color-cream);
  }

  .btn-ghost {
    background: transparent;
    color: var(--color-cream);
    border: 2px solid var(--color-cream);
  }

  .btn-ghost:hover {
    background: var(--color-cream);
    color: var(--color-orange);
    transform: translateY(-2px);
  }
</style>
