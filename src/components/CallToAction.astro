---
---

<section class="cta">
  <div class="container cta-inner" data-animate="fade-up">
    <h2>Pull Up a Chair</h2>
    <p>
      If our work resonates, we warmly invite you to connect. SuperBenefit
      is an open community &mdash; whether you&rsquo;re a builder, researcher,
      funder, or simply curious, there&rsquo;s a place for you here.
    </p>
    <div class="cta-links">
      <a
        href="https://discord.gg/q95fFXGu67"
        class="cta-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="cta-link-icon" aria-hidden="true">&#9679;</span>
        Discord
      </a>
      <a
        href="https://github.com/superbenefit"
        class="cta-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="cta-link-icon" aria-hidden="true">&#9900;</span>
        GitHub
      </a>
      <a
        href="https://knowledge.superbenefit.org"
        class="cta-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="cta-link-icon" aria-hidden="true">&#9733;</span>
        Knowledge Garden
      </a>
    </div>
  </div>
</section>

<style>
  .cta {
    background: var(--color-charcoal);
    padding-block: var(--space-2xl);
  }

  .cta-inner {
    text-align: center;
    max-width: 640px;
  }

  .cta h2 {
    color: var(--color-cream);
    margin-block-end: var(--space-md);
  }

  .cta p {
    color: var(--color-cream);
    opacity: 0.8;
    font-size: var(--text-lg);
    line-height: 1.7;
    margin-block-end: var(--space-xl);
    margin-inline: auto;
  }

  .cta-links {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.7em 1.5em;
    border: 1px solid rgb(var(--color-cream-rgb) / 0.2);
    border-radius: 50px;
    color: var(--color-cream);
    font-weight: 500;
    font-size: var(--text-sm);
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast),
      transform var(--transition-fast),
      color var(--transition-fast);
    text-decoration: none;
  }

  .cta-link:hover {
    background: var(--color-orange);
    border-color: var(--color-orange);
    color: var(--color-cream);
    transform: translateY(-2px);
  }

  .cta-link-icon {
    font-size: 1.2em;
  }
</style>
