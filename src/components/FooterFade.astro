<div class="footer-fade" aria-hidden="true">
  <!-- Top layer — tight oscillation near the top, always covers the rim -->
  <svg viewBox="0 0 1440 120" preserveAspectRatio="none" class="fade-wave fade-shallow">
    <path d="M0,3 Q240,-2 480,3 Q720,8 960,3 Q1200,-2 1440,5 L1440,120 L0,120 Z" />
  </svg>

  <!-- Mid layer — wider sweeps through the middle -->
  <svg viewBox="0 0 1440 120" preserveAspectRatio="none" class="fade-wave fade-mid">
    <path d="M0,30 Q180,5 360,30 Q540,55 720,30 Q900,5 1080,30 Q1260,55 1440,35 L1440,120 L0,120 Z" />
  </svg>

  <!-- Deep layer — one long, slow undulation reaching toward the bottom -->
  <svg viewBox="0 0 1440 120" preserveAspectRatio="none" class="fade-wave fade-deep">
    <path d="M0,75 Q240,45 480,75 Q720,105 960,75 Q1200,45 1440,80 L1440,120 L0,120 Z" />
  </svg>
</div>

<style>
  .footer-fade {
    position: relative;
    height: 120px;
    margin-top: -120px;
    background: var(--color-black);
    line-height: 0;
    overflow: hidden;
  }

  .fade-wave {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .fade-shallow path {
    fill: var(--color-charcoal);
    opacity: 0.7;
  }

  .fade-mid path {
    fill: var(--color-charcoal);
    opacity: 0.45;
  }

  .fade-deep path {
    fill: var(--color-charcoal);
    opacity: 0.25;
  }

  @media (max-width: 768px) {
    .footer-fade {
      height: 80px;
      margin-top: -80px;
    }
  }
</style>
