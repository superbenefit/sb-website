# SuperBenefit Website — Environment Variables
# Copy this file to .env and fill in values. Never commit .env.

# URL for the SuperBenefit knowledge server API.
# When set, blog posts are loaded from this endpoint at build time.
# Leave blank to use built-in mock data (default for local development).
KNOWLEDGE_API_URL=

# ─── /contact form ──────────────────────────────────────────────────────
# Recipient address for the /contact form.
# In production, set as a Cloudflare secret:
#   wrangler secret put CONTACT_EMAIL
# In local dev, this value is read directly by the action.
# NOTE: must also be listed in wrangler.jsonc send_email.destination_addresses.
CONTACT_EMAIL=contact@superbenefit.org

# Turnstile secret key (server-side verification).
# In production, set as a Cloudflare secret:
#   wrangler secret put TURNSTILE_SECRET_KEY
# In local dev, the always-pass test key is used if unset.
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Turnstile site key (public, sent to the client).
# In production, override via wrangler [vars] or dashboard with the real key.
# In local dev, the always-pass test key is used if unset.
PUBLIC_TURNSTILE_SITE_KEY=1x30000000000000000000AA
